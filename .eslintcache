/TennaParty/src/screens/Search/Shell.tsx:231:7\n  229 |     if (IS_NATIVE) {\n  230 |       // eslint-disable-next-line react-hooks/set-state-in-effect\n> 231 |       updateSearchText(queryParam)\n      |       ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  232 |     }\n  233 |   }, [queryParam, updateSearchText])\n  234 |   useFocusEffect(",["1477"],["1478","1479"],["1480"],["1481","1482"],["1483"],["1484","1485"],["1486"],"Error: This value cannot be modified\n\nModifying a value returned from 'useReducer()', which should not be modified directly. Use the dispatch function to update instead.\n\n/home/kris/Developer/ATProto/TennaParty/src/screens/Signup/index.tsx:107:9\n  105 |         // OK to mutate assuming it's never read in render.\n  106 |         // eslint-disable-next-line react-hooks/immutability, react-compiler/react-compiler\n> 107 |         state.pendingSubmit.mutableProcessed = true\n      |         ^^^^^^^^^^^^^^^^^^^ `state` cannot be modified\n  108 |         void submit(state, dispatch)\n  109 |       }\n  110 |     }",["1487"],"Mutating a value returned from 'useReducer()', which should not be mutated. Use the dispatch function to update instead",["1488"],["1489","1490"],["1491","1492"],["1493","1494"],["1495","1496"],["1497","1498"],["1499","1500"],["1501","1502"],["1503","1504"],["1505","1506"],["1507","1508"],["1509","1510"],["1511","1512"],"import-x/no-named-as-default","Using exported name 'ProgressPie' as identifier for default export.","ImportDefaultSpecifier","default",["1513","1514"],["1515","1516"],["1517","1518"],["1519","1520"],["1521","1522"],["1523","1524"],"React Hook useMemo has missing dependencies: 'disableComposerPrompt' and 'hideUnreplyablePosts'. Either include them or remove the dependency array.",["1525"],"React Hook useCallback has a missing dependency: 't.palette.primary_500'. Either include it or remove the dependency array.",["1526"],"react-hooks/purity","Error: Cannot call impure function during 